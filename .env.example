# URL to the backend text file / endpoint that returns 8 numbers (one per line)
# Example: VITE_DATA_URL=http://raspberrypi.local:8080/scores.txt
# Leave unset to run in DEMO mode (random auto-incrementing scores)
VITE_DATA_URL=

# How often to poll the backend (milliseconds). Default: 250
VITE_POLL_MS=250
